# Intercom API Configuration
INTERCOM_ACCESS_TOKEN=your_intercom_access_token_here

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Optional: Filter articles by collection or tag
# INTERCOM_COLLECTION_ID=your_collection_id_here
# INTERCOM_TAG_ID=your_tag_id_here

# Supabase (dashboard + sync)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your_service_role_key
# Option A - Create table via script: set ONE of these, then run python create_supabase_table.py
#   SUPABASE_DB_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres  (from Dashboard > Database > Connection string URI)
#   SUPABASE_PAT=your_personal_access_token  (from https://supabase.com/dashboard/account/tokens; script uses Management API to run SQL)
